@model IEnumerable<SchoolSystem.ViewModels.SchoolVm.StudentDepartmentVM.StudentDepartmentListVM>

<h1>Department List</h1>

<table class="table table-bordered table-striped table-hover">
    <tr>
        <th>Department Name</th>
        <th>Department Code</th>
        <th>Actions</th>
    </tr>

    @foreach(var dept in Model)
    {
        <tr>
            <td>@dept.StudentDepartmentName</td>
            <td>@dept.StudentDepartmentCode</td>
            <td>
                <a asp-action="Edit" class="btn btn-warning btn-sm" asp-route-id="@dept.StudentDepartmentId">Update</a>
                <a asp-action="Delete" class="btn btn-danger btn-sm" asp-route-id="@dept.StudentDepartmentId">Delete</a>
            </td>
        </tr>
    }
</table>
<a asp-action="Create" class="btn btn-primary btn-sm">Create</a>

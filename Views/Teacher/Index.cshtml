@model IEnumerable<SchoolSystem.ViewModels.SchoolVm.TeacherVM.TeacherListVM>

<h1>Lecturer List</h1>

<table class="table table-bordered table-striped table-hover">
    <tr>
        <th>Full Name</th>
        <th>Email</th>
        <th>Phone Number</th>
        <th>Actions</th>
    </tr>

    @foreach(var teacher in Model)
    {
        <tr>
            <td>@teacher.TeacherName</td>
            <td>@teacher.TeacherEmail</td>
            <td>@teacher.TeacherPhoneNO</td>
            <td>
                <a asp-action="Edit" class="btn btn-warning btn-sm" asp-route-id="@teacher.TeacherId">Update</a>
                <a asp-action="Delete" class="btn btn-danger btn-sm" asp-route-id="@teacher.TeacherId">Delete</a>
            </td>
        </tr>
    }
</table>
<a asp-action="Create" class="btn btn-primary btn-sm">Create</a>



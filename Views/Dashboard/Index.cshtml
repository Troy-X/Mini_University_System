@model SchoolSystem.ViewModels.SchoolVm.DashboardVM.DashboardListVM

<h1 class="mb-4">Dashboard</h1>

<div class="container">

    <!-- 📊 CARDS -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card bg-primary text-white shadow-sm">
                <div class="card-body">
                    <h5>Total Students</h5>
                    <h2>@Model.TotalStudents</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body">
                    <h5>Total Lecturers</h5>
                    <h2>@Model.TotalTeachers</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-info text-white shadow-sm">
                <div class="card-body">
                    <h5>Total Courses</h5>
                    <h2>@Model.TotalCourses</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-dark text-white shadow-sm">
                <div class="card-body">
                    <h5>Total Departments</h5>
                    <h2>@Model.TotalDepartments</h2>
                </div>
            </div>
        </div>

    </div>

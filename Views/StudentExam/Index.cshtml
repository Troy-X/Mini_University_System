@model IEnumerable<SchoolSystem.ViewModels.SchoolVm.StudentExamVM.StudentExamListVM>

<table class="table table-striped table-bordered table-hover">
    <tr>
        <th>Student Name</th>
        <th>Exam Name</th>
        <th>Score</th>
        <th>Grade</th>
        <th>Actions</th>
    </tr>

    @foreach(var result in Model)
    {
        <tr>
            <td>@result.StudentName</td>
            <td>@result.ExamName</td>
            <td>@result.Score</td>
            <td>@result.Grade</td>
            <td>
                <a asp-action="Edit" class="btn btn-warning btn-sm" asp-route-id="@result.StudentExamId">Update</a>
                <a asp-action="Delete" class="btn btn-danger btn-sm" asp-route-id="@result.StudentExamId">Delete</a>

            </td>
        </tr>
    }
</table>
<a asp-action="Create" class="btn btn-primary btn-sm">Create</a>

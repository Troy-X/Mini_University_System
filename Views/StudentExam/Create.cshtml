@model SchoolSystem.ViewModels.SchoolVm.StudentExamVM.StudentExamCreateVM

@{
    var students = ViewData["Students"] as IEnumerable<SchoolSystem.ViewModels.SchoolVm.StudentVM.StudentListVM>;

    var exams = ViewData["Exams"] as IEnumerable<SchoolSystem.ViewModels.SchoolVm.ExamVM.ExamListVM>;
}

<form method="post" asp-action="Create">

    <label asp-for="StudentId">Student Name</label>
    <select asp-for="StudentId" class="form-control">
        <option value="">-- Select Student --</option>

        @foreach(var student in students)
        {
            <option value="@student.StudentId">@student.StudentName</option>
        }
    </select>

    <label asp-for="ExamId">Exam Name</label>
    <select asp-for="ExamId" class="form-control">
        <option value="">-- Select Exam --</option>

        @foreach(var exam in exams)
        {
            <option value="@exam.ExamId">@exam.ExamName</option>
        }
    </select>

    <label asp-for="Score">Score</label>
    <input asp-for="Score" class="form-control" />

    <label asp-for="Grade">Grade</label>
    <input asp-for="Grade" class="form-control" />

    <br />
    <button class="btn btn-success btn-sm" type="submit">Save</button>
</form>